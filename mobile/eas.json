{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Release",
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
   "testflight": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "distribution": "internal"
      },
      "ios": {
        "buildConfiguration": "Release",
        "simulator": false,
        "image": "latest"
      }
    },
    "production": {
      "ios": {
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "ascApiKeyIssuerId": "11ab341a-3866-484a-98b0-9844570cb080",
        "ascApiKeyId": "3YC4L83GPY",
        "ascApiKeyPath": "/tmp/asc_key.p8"
      }
    }
  }
}
